# Copy to .env and adjust. The .env file is gitignored (it may hold secrets).
# docker-compose loads this; the backend also reads these as env vars.

# ── Postgres ─────────────────────────────────────────────
# DB_HOST_PORT = port published on your host. Defaults to 5434 to match the
#   app's local default (5432 is often taken by a native Postgres). Free to use
#   5432 if you don't have one — a local IDE run then needs DB_PORT=5434 unset.
# DB_PORT      = container-internal port used by the app inside docker.
DB_HOST_PORT=5434
DB_PORT=5432
DB_NAME=notifyhub
DB_USER=notifyhub
DB_PASSWORD=notifyhub

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── App ──────────────────────────────────────────────────
APP_PORT=8080

# ── Delivery channel ─────────────────────────────────────
# DELIVERY_MODE: "log" (default, no external send) or "smtp" (real email).
# For smtp, fill in your provider's SMTP settings below.
DELIVERY_MODE=log
MAIL_FROM=no-reply@notifyhub.local

# SMTP (only used when DELIVERY_MODE=smtp)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
