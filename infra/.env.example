# Copy to .env and adjust. The .env file is gitignored (it may hold secrets).
# docker-compose loads this; the backend also reads these as env vars.

# ── Postgres ─────────────────────────────────────────────
# DB_HOST_PORT = port published on your host. Defaults to 5434 to match the
#   app's local default (5432 is often taken by a native Postgres). Free to use
#   5432 if you don't have one — a local IDE run then needs DB_PORT=5434 unset.
# DB_PORT      = container-internal port used by the app inside docker.
DB_HOST_PORT=5434
DB_PORT=5432
DB_NAME=notifyhub
DB_USER=notifyhub
DB_PASSWORD=notifyhub

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── App ──────────────────────────────────────────────────
APP_PORT=8080

# ── Security ─────────────────────────────────────────────
# API key required on all endpoints except /actuator/health. Comma-separated
# to rotate (old + new valid at once). CHANGE THIS in any real environment.
# The frontend console sends its own key via VITE_API_KEY (frontend build env).
API_KEY=dev-local-key

# ── Delivery channel ─────────────────────────────────────
# DELIVERY_MODE: "log" (default, no external send) or "smtp" (real email).
# For smtp, fill in your provider's SMTP settings below.
DELIVERY_MODE=log
MAIL_FROM=no-reply@notifyhub.local

# SMTP (only used when DELIVERY_MODE=smtp). Set MAIL_FROM = SMTP_USER for
# Gmail/Outlook (they rewrite the From to the authenticated account).
#
# Provider cheat-sheet:
#   Gmail    SMTP_HOST=smtp.gmail.com          PORT=587 STARTTLS=true SSL=false  (use an App Password)
#   Outlook  SMTP_HOST=smtp-mail.outlook.com   PORT=587 STARTTLS=true SSL=false  (personal Hotmail/Outlook)
#   Office365 SMTP_HOST=smtp.office365.com      PORT=587 STARTTLS=true SSL=false
#   Yahoo    SMTP_HOST=smtp.mail.yahoo.com     PORT=465 STARTTLS=false SSL=true  (use an App Password)
#   465 SSL  any implicit-TLS host             PORT=465 STARTTLS=false SSL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false
